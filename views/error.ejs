<div class="container py-5 text-center" style="min-height:60vh;display:flex;align-items:center;justify-content:center;">
  <div>
    <div style="font-size:4rem;opacity:0.3;" class="mb-3">⚠️</div>
    <h2 style="font-family:'Playfair Display',serif;color:var(--primary);">Something Went Wrong</h2>
    <p class="text-muted"><%= typeof message !== 'undefined' ? message : 'An unexpected error occurred.' %></p>
    <a href="/" class="btn btn-primary-custom mt-3">Go Home</a>
  </div>
</div>
