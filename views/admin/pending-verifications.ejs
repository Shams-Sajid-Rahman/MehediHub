<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 style="font-family:'Playfair Display',serif;color:#333;">Pending NID Verifications</h4>
  <span class="badge bg-warning text-dark fs-6"><%= verifications.length %> pending</span>
</div>

<% if (verifications.length === 0) { %>
  <div class="card border-0 shadow-sm p-5 text-center">
    <i class="bi bi-check-circle-fill text-success mb-3" style="font-size:3rem;"></i>
    <h5>All verifications are up to date!</h5>
    <p class="text-muted">No pending verifications at this time.</p>
  </div>
<% } else { %>
  <div class="card border-0 shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead style="background:#f8f9fa;">
          <tr>
            <th>User</th>
            <th>Role</th>
            <th>NID Number</th>
            <th>Name on NID</th>
            <th>Submitted</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% verifications.forEach(v => { %>
          <tr>
            <td>
              <div class="fw-semibold"><%= v.full_name %></div>
              <div class="text-muted small"><%= v.email %></div>
              <div class="text-muted small"><%= v.phone %></div>
            </td>
            <td>
              <span class="badge <%= v.role === 'artist' ? 'bg-primary' : 'bg-info' %>">
                <%= v.role %>
              </span>
            </td>
            <td><code><%= v.nid_number || 'Not extracted' %></code></td>
            <td><%= v.name_on_nid || '—' %></td>
            <td class="text-muted small"><%= new Date(v.created_at).toLocaleDateString('en-BD') %></td>
            <td>
              <div class="d-flex gap-2">
                <a href="/admin/verifications/<%= v.id %>" class="btn btn-sm btn-outline-primary">
                  <i class="bi bi-eye me-1"></i>Review
                </a>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>
