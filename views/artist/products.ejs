<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 style="font-family:'Playfair Display',serif;color:var(--primary);">My Products</h4>
  <a href="/artist/products/new" class="btn btn-primary-custom btn-sm">
    <i class="bi bi-plus-circle me-1"></i>Add Product
  </a>
</div>

<% if (products.length === 0) { %>
  <div class="card border-0 shadow-sm p-5 text-center">
    <i class="bi bi-bag mb-3" style="font-size:3rem;color:var(--primary);opacity:0.4;"></i>
    <h5>No products yet</h5>
    <p class="text-muted">List your Mehedi supplies and products.</p>
    <a href="/artist/products/new" class="btn btn-primary-custom mx-auto" style="width:fit-content;">Add Product</a>
  </div>
<% } else { %>
  <div class="row g-4">
    <% products.forEach(p => { %>
    <div class="col-sm-6 col-xl-4">
      <div class="card border-0 shadow-sm h-100">
        <div style="height:160px;overflow:hidden;">
          <% if (p.image_url) { %>
            <img src="<%= p.image_url %>" class="w-100 h-100" style="object-fit:cover;" alt="<%= p.name %>" />
          <% } else { %>
            <div class="w-100 h-100 d-flex align-items-center justify-content-center" style="background:#f5e6d3;font-size:3rem;">🌿</div>
          <% } %>
        </div>
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start mb-1">
            <h6 class="fw-semibold mb-0"><%= p.name %></h6>
            <span class="badge <%= p.is_active ? 'bg-success' : 'bg-secondary' %>" style="font-size:0.65rem;"><%= p.is_active ? 'Active' : 'Off' %></span>
          </div>
          <span class="badge mb-2" style="background:var(--accent);color:#3a1a00;font-size:0.7rem;"><%= p.category %></span>
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <div class="fw-bold" style="color:var(--primary);">৳<%= p.price %></div>
              <div class="text-muted small">Stock: <%= p.stock %></div>
            </div>
            <div class="d-flex gap-1">
              <a href="/artist/products/<%= p.id %>/edit" class="btn btn-sm btn-outline-primary py-0 px-2">Edit</a>
              <form action="/artist/products/<%= p.id %>/delete" method="POST" onsubmit="return confirm('Delete?')">
                <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-2">Del</button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
<% } %>
