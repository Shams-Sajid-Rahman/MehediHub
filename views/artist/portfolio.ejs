<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 style="font-family:'Playfair Display',serif;color:var(--primary);">My Portfolio</h4>
</div>

<!-- Upload Form -->
<div class="card border-0 shadow-sm p-4 mb-4">
  <h6 class="fw-semibold mb-3">Add Portfolio Image</h6>
  <form action="/artist/portfolio/add" method="POST" enctype="multipart/form-data">
    <div class="row g-3 align-items-end">
      <div class="col-md-5">
        <label class="form-label small fw-semibold">Image *</label>
        <input type="file" name="portfolio_image" class="form-control form-control-sm" accept="image/*" required />
      </div>
      <div class="col-md-5">
        <label class="form-label small fw-semibold">Caption</label>
        <input type="text" name="caption" class="form-control form-control-sm" placeholder="e.g. Bridal design for Eid 2024" />
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-primary-custom btn-sm w-100">Upload</button>
      </div>
    </div>
  </form>
</div>

<!-- Gallery -->
<% if (portfolios.length === 0) { %>
  <div class="card border-0 shadow-sm p-5 text-center">
    <i class="bi bi-images mb-3" style="font-size:3rem;color:var(--primary);opacity:0.4;"></i>
    <h5>No portfolio images yet</h5>
    <p class="text-muted small">Upload your work to attract more customers.</p>
  </div>
<% } else { %>
  <div class="row g-3">
    <% portfolios.forEach(item => { %>
    <div class="col-sm-6 col-md-4 col-lg-3">
      <div class="card border-0 shadow-sm h-100">
        <div style="height:200px;overflow:hidden;">
          <img src="<%= item.image_url %>" class="w-100 h-100" style="object-fit:cover;" alt="<%= item.caption || 'Portfolio' %>" />
        </div>
        <div class="card-body p-2">
          <% if (item.caption) { %>
            <p class="text-muted small mb-2"><%= item.caption %></p>
          <% } %>
          <form action="/artist/portfolio/<%= item.id %>/delete" method="POST" onsubmit="return confirm('Delete this image?')">
            <button type="submit" class="btn btn-sm btn-outline-danger w-100 py-0">
              <i class="bi bi-trash me-1"></i>Delete
            </button>
          </form>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
<% } %>
