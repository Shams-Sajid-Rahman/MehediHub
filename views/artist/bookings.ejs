<h4 class="mb-4" style="font-family:'Playfair Display',serif;color:var(--primary);">My Bookings</h4>

<% if (bookings.length === 0) { %>
  <div class="card border-0 shadow-sm p-5 text-center">
    <i class="bi bi-calendar-check mb-3" style="font-size:3rem;color:var(--primary);opacity:0.4;"></i>
    <h5>No bookings yet</h5>
    <p class="text-muted">Bookings from customers will appear here.</p>
  </div>
<% } else { %>
  <div class="card border-0 shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead style="background:#fff8f0;">
          <tr>
            <th>Customer</th>
            <th>Service</th>
            <th>Event</th>
            <th>Location</th>
            <th>Price</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% bookings.forEach(b => { %>
          <tr>
            <td>
              <div class="fw-semibold small"><%= b.customer_name %></div>
              <div class="text-muted" style="font-size:0.75rem;"><%= b.customer_phone %></div>
            </td>
            <td>
              <div class="small fw-semibold"><%= b.service_title %></div>
              <span class="badge" style="background:var(--accent);color:#3a1a00;font-size:0.65rem;"><%= b.service_category %></span>
            </td>
            <td class="small">
              <div><%= new Date(b.event_date).toLocaleDateString('en-BD') %></div>
              <div class="text-muted"><%= b.event_time ? b.event_time.substring(0, 5) : '' %></div>
            </td>
            <td class="small text-muted" style="max-width:150px;white-space:normal;"><%= (b.event_location || '—').substring(0, 60) %></td>
            <td class="fw-semibold small" style="color:var(--primary);">৳<%= b.total_price %></td>
            <td>
              <span class="badge <%=
                b.status === 'completed' ? 'bg-success' :
                b.status === 'confirmed' ? 'bg-primary' :
                b.status === 'pending' ? 'bg-warning text-dark' :
                b.status === 'cancelled' ? 'bg-secondary' : 'bg-danger' %>">
                <%= b.status %>
              </span>
            </td>
            <td>
              <% if (b.status === 'pending') { %>
              <div class="d-flex gap-1">
                <form action="/artist/bookings/<%= b.id %>/accept" method="POST">
                  <button type="submit" class="btn btn-success btn-sm py-0 px-2">Accept</button>
                </form>
                <form action="/artist/bookings/<%= b.id %>/reject" method="POST">
                  <button type="submit" class="btn btn-outline-danger btn-sm py-0 px-2">Reject</button>
                </form>
              </div>
              <% } else if (b.status === 'confirmed') { %>
              <form action="/artist/bookings/<%= b.id %>/complete" method="POST">
                <button type="submit" class="btn btn-primary btn-sm py-0 px-2">Mark Complete</button>
              </form>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>
