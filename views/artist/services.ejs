<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 style="font-family:'Playfair Display',serif;color:var(--primary);">My Services</h4>
  <a href="/artist/services/new" class="btn btn-primary-custom btn-sm">
    <i class="bi bi-plus-circle me-1"></i>Add Service
  </a>
</div>

<% if (services.length === 0) { %>
  <div class="card border-0 shadow-sm p-5 text-center">
    <i class="bi bi-list-check mb-3" style="font-size:3rem;color:var(--primary);opacity:0.4;"></i>
    <h5>No services yet</h5>
    <p class="text-muted">Add your first service to start receiving bookings.</p>
    <a href="/artist/services/new" class="btn btn-primary-custom mx-auto" style="width:fit-content;">Add Service</a>
  </div>
<% } else { %>
  <div class="card border-0 shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead style="background:#fff8f0;">
          <tr>
            <th>Title</th>
            <th>Category</th>
            <th>Price</th>
            <th>Duration</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% services.forEach(s => { %>
          <tr>
            <td class="fw-semibold"><%= s.title %></td>
            <td><span class="badge" style="background:var(--accent);color:#3a1a00;"><%= s.category %></span></td>
            <td>৳<%= s.price %></td>
            <td><%= s.duration_minutes %> min</td>
            <td><span class="badge <%= s.is_active ? 'bg-success' : 'bg-secondary' %>"><%= s.is_active ? 'Active' : 'Inactive' %></span></td>
            <td>
              <div class="d-flex gap-1">
                <a href="/artist/services/<%= s.id %>/edit" class="btn btn-sm btn-outline-primary py-0 px-2">Edit</a>
                <form action="/artist/services/<%= s.id %>/delete" method="POST" onsubmit="return confirm('Delete this service?')">
                  <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-2">Delete</button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>
