<div class="d-flex align-items-center gap-3 mb-4">
  <a href="/artist/products" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
  <h4 class="mb-0" style="font-family:'Playfair Display',serif;color:var(--primary);"><%= product ? 'Edit Product' : 'Add New Product' %></h4>
</div>

<div class="row justify-content-center">
  <div class="col-md-7">
    <div class="card border-0 shadow-sm p-4">
      <form action="<%= formAction %>" method="POST" enctype="multipart/form-data">
        <div class="mb-3">
          <label class="form-label fw-semibold">Product Name *</label>
          <input type="text" name="name" class="form-control" value="<%= product ? product.name : '' %>" required placeholder="e.g. Premium Henna Cone" />
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Category *</label>
          <select name="category" class="form-select" required>
            <% ['cone','stencil','powder','oil','kit','accessory'].forEach(cat => { %>
              <option value="<%= cat %>" <%= product && product.category === cat ? 'selected' : '' %>><%= cat.charAt(0).toUpperCase() + cat.slice(1) %></option>
            <% }) %>
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Description</label>
          <textarea name="description" class="form-control" rows="3" placeholder="Describe the product..."><%= product ? product.description || '' : '' %></textarea>
        </div>
        <div class="row g-3 mb-3">
          <div class="col-sm-6">
            <label class="form-label fw-semibold">Price (৳) *</label>
            <input type="number" name="price" class="form-control" value="<%= product ? product.price : '' %>" required min="0" step="10" />
          </div>
          <div class="col-sm-6">
            <label class="form-label fw-semibold">Stock Quantity *</label>
            <input type="number" name="stock" class="form-control" value="<%= product ? product.stock : 0 %>" required min="0" />
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Product Image</label>
          <input type="file" name="product_image" class="form-control form-control-sm" accept="image/*" />
          <% if (product && product.image_url) { %>
            <img src="<%= product.image_url %>" class="mt-2 rounded" style="max-height:100px;" alt="Current" />
          <% } %>
        </div>
        <% if (product) { %>
        <div class="mb-3">
          <div class="form-check">
            <input type="checkbox" name="is_active" class="form-check-input" id="is_active" <%= product.is_active ? 'checked' : '' %> />
            <label class="form-check-label" for="is_active">Product is active</label>
          </div>
        </div>
        <% } %>
        <div class="d-flex gap-2 mt-4">
          <a href="/artist/products" class="btn btn-outline-secondary">Cancel</a>
          <button type="submit" class="btn btn-primary-custom flex-grow-1"><%= product ? 'Update Product' : 'Create Product' %></button>
        </div>
      </form>
    </div>
  </div>
</div>
