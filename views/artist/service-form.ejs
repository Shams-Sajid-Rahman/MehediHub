<div class="d-flex align-items-center gap-3 mb-4">
  <a href="/artist/services" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
  <h4 class="mb-0" style="font-family:'Playfair Display',serif;color:var(--primary);"><%= service ? 'Edit Service' : 'Add New Service' %></h4>
</div>

<div class="row justify-content-center">
  <div class="col-md-7">
    <div class="card border-0 shadow-sm p-4">
      <form action="<%= formAction %>" method="POST">
        <div class="mb-3">
          <label class="form-label fw-semibold">Service Title *</label>
          <input type="text" name="title" class="form-control" value="<%= service ? service.title : '' %>" required placeholder="e.g. Full Bridal Mehedi Package" />
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Category *</label>
          <select name="category" class="form-select" required>
            <% ['bridal','party','simple','arabic','indian','custom'].forEach(cat => { %>
              <option value="<%= cat %>" <%= service && service.category === cat ? 'selected' : '' %>><%= cat.charAt(0).toUpperCase() + cat.slice(1) %></option>
            <% }) %>
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Description</label>
          <textarea name="description" class="form-control" rows="3" placeholder="Describe what's included in this service..."><%= service ? service.description || '' : '' %></textarea>
        </div>
        <div class="row g-3 mb-3">
          <div class="col-sm-6">
            <label class="form-label fw-semibold">Price (৳) *</label>
            <input type="number" name="price" class="form-control" value="<%= service ? service.price : '' %>" required min="0" step="50" placeholder="e.g. 5000" />
          </div>
          <div class="col-sm-6">
            <label class="form-label fw-semibold">Duration (minutes) *</label>
            <input type="number" name="duration_minutes" class="form-control" value="<%= service ? service.duration_minutes : 60 %>" required min="15" step="15" />
          </div>
        </div>
        <% if (service) { %>
        <div class="mb-3">
          <div class="form-check">
            <input type="checkbox" name="is_active" class="form-check-input" id="is_active" <%= service.is_active ? 'checked' : '' %> />
            <label class="form-check-label" for="is_active">Service is active</label>
          </div>
        </div>
        <% } %>
        <div class="d-flex gap-2 mt-4">
          <a href="/artist/services" class="btn btn-outline-secondary">Cancel</a>
          <button type="submit" class="btn btn-primary-custom flex-grow-1"><%= service ? 'Update Service' : 'Create Service' %></button>
        </div>
      </form>
    </div>
  </div>
</div>
