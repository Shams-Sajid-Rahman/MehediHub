<h4 class="mb-4" style="font-family:'Playfair Display',serif;color:var(--primary);">Product Orders</h4>

<% if (orders.length === 0) { %>
  <div class="card border-0 shadow-sm p-5 text-center">
    <i class="bi bi-box-seam mb-3" style="font-size:3rem;color:var(--primary);opacity:0.4;"></i>
    <h5>No orders yet</h5>
    <p class="text-muted">Orders for your products will appear here.</p>
  </div>
<% } else { %>
  <div class="card border-0 shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead style="background:#fff8f0;">
          <tr>
            <th>Order ID</th>
            <th>Customer</th>
            <th>Amount</th>
            <th>Status</th>
            <th>Date</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% orders.forEach(o => { %>
          <tr>
            <td><code>#<%= o.id %></code></td>
            <td>
              <div class="small fw-semibold"><%= o.customer_name %></div>
              <div class="text-muted" style="font-size:0.75rem;"><%= o.customer_phone %></div>
            </td>
            <td class="fw-semibold" style="color:var(--primary);">৳<%= o.total_amount %></td>
            <td>
              <span class="badge <%=
                o.status === 'delivered' ? 'bg-success' :
                o.status === 'shipped' ? 'bg-primary' :
                o.status === 'confirmed' ? 'bg-info' :
                o.status === 'pending' ? 'bg-warning text-dark' : 'bg-secondary' %>">
                <%= o.status %>
              </span>
            </td>
            <td class="text-muted small"><%= new Date(o.created_at).toLocaleDateString('en-BD') %></td>
            <td>
              <% if (o.status === 'confirmed') { %>
              <form action="/artist/orders/<%= o.id %>/ship" method="POST">
                <button type="submit" class="btn btn-primary btn-sm py-0 px-2">Mark Shipped</button>
              </form>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>
