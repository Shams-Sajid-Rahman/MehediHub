<h4 class="mb-4" style="font-family:'Playfair Display',serif;color:var(--primary);">Checkout</h4>

<div class="row g-4">
  <div class="col-lg-7">
    <div class="card border-0 shadow-sm p-4">
      <h5 class="fw-semibold mb-4">Shipping Details</h5>
      <form action="/customer/checkout" method="POST">
        <div class="mb-3">
          <label class="form-label fw-semibold">Full Shipping Address *</label>
          <textarea name="shipping_address" class="form-control" rows="3" required placeholder="House #, Road, Area, District..."><%= user.full_name ? '' : '' %></textarea>
        </div>
        <div class="mb-4">
          <label class="form-label fw-semibold">Contact Phone *</label>
          <input type="text" name="phone" class="form-control" value="<%= user.phone || '' %>" required placeholder="01XXXXXXXXX" />
        </div>
        <div class="alert alert-info small mb-4">
          <i class="bi bi-info-circle me-2"></i>
          Payment is Cash on Delivery. Please have the exact amount ready.
        </div>
        <button type="submit" class="btn btn-primary-custom w-100 btn-lg">
          <i class="bi bi-check-circle me-2"></i>Place Order (৳<%= total.toFixed(2) %>)
        </button>
      </form>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="card border-0 shadow-sm p-4">
      <h5 class="fw-semibold mb-4">Order Summary</h5>
      <% cartItems.forEach(item => { %>
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="d-flex align-items-center gap-2">
          <% if (item.image_url) { %>
            <img src="<%= item.image_url %>" style="width:40px;height:40px;object-fit:cover;border-radius:4px;" />
          <% } else { %>
            <div style="width:40px;height:40px;background:#f5e6d3;border-radius:4px;display:flex;align-items:center;justify-content:center;">🌿</div>
          <% } %>
          <div>
            <div class="small fw-semibold"><%= item.name %></div>
            <div class="text-muted" style="font-size:0.75rem;">Qty: <%= item.quantity %></div>
          </div>
        </div>
        <div class="fw-semibold small" style="color:var(--primary);">৳<%= (item.price * item.quantity).toFixed(2) %></div>
      </div>
      <% }) %>
      <hr />
      <div class="d-flex justify-content-between fw-bold">
        <span>Total</span>
        <span style="color:var(--primary);">৳<%= total.toFixed(2) %></span>
      </div>
    </div>
  </div>
</div>
