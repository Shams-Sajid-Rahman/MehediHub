<div class="container py-5">
  <div class="row g-4">
    <!-- Filters -->
    <div class="col-lg-3">
      <div class="card border-0 shadow-sm p-4 sticky-top" style="top:80px;">
        <h5 class="fw-semibold mb-4" style="color:var(--primary);">Filter Products</h5>
        <form method="GET" action="/products">
          <div class="mb-3">
            <label class="form-label small fw-semibold">Category</label>
            <select name="category" class="form-select form-select-sm">
              <option value="">All Categories</option>
              <% ['cone','stencil','powder','oil','kit','accessory'].forEach(cat => { %>
                <option value="<%= cat %>" <%= filters.category === cat ? 'selected' : '' %>><%= cat.charAt(0).toUpperCase() + cat.slice(1) %></option>
              <% }) %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label small fw-semibold">Min Price (৳)</label>
            <input type="number" name="minPrice" class="form-control form-control-sm" value="<%= filters.minPrice || '' %>" placeholder="0" />
          </div>
          <div class="mb-4">
            <label class="form-label small fw-semibold">Max Price (৳)</label>
            <input type="number" name="maxPrice" class="form-control form-control-sm" value="<%= filters.maxPrice || '' %>" placeholder="Any" />
          </div>
          <button type="submit" class="btn btn-primary-custom w-100 btn-sm">Apply</button>
          <a href="/products" class="btn btn-outline-secondary w-100 mt-2 btn-sm">Clear</a>
        </form>
      </div>
    </div>

    <!-- Products Grid -->
    <div class="col-lg-9">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 style="color:var(--primary);font-family:'Playfair Display',serif;">Mehedi Supplies</h4>
        <span class="text-muted small"><%= products.length %> product(s)</span>
      </div>

      <% if (products.length === 0) { %>
        <div class="text-center py-5">
          <div style="font-size:4rem;opacity:0.3;">🌿</div>
          <h5 class="text-muted mt-3">No products found.</h5>
        </div>
      <% } else { %>
        <div class="row g-4">
          <% products.forEach(product => { %>
          <div class="col-sm-6 col-xl-4">
            <div class="card border-0 shadow-sm h-100 product-card">
              <div style="height:200px;overflow:hidden;">
                <% if (product.image_url) { %>
                  <img src="<%= product.image_url %>" class="w-100 h-100" style="object-fit:cover;" alt="<%= product.name %>" />
                <% } else { %>
                  <div class="w-100 h-100 d-flex align-items-center justify-content-center" style="background:#f5e6d3;font-size:4rem;">🌿</div>
                <% } %>
              </div>
              <div class="card-body">
                <span class="badge mb-2" style="background:var(--accent);color:#3a1a00;"><%= product.category %></span>
                <h5 class="fw-semibold mb-1"><%= product.name %></h5>
                <p class="text-muted small mb-2">by <%= product.artist_name %></p>
                <p class="text-muted small mb-3"><%= (product.description || '').substring(0, 80) %></p>
                <div class="d-flex justify-content-between align-items-center">
                  <div>
                    <div class="fw-bold" style="color:var(--primary);font-size:1.1rem;">৳<%= product.price %></div>
                    <div class="text-muted small">Stock: <%= product.stock %></div>
                  </div>
                  <a href="/products/<%= product.id %>" class="btn btn-primary-custom btn-sm">View</a>
                </div>
              </div>
            </div>
          </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</div>
