<div class="container py-5">
  <div class="row g-4">
    <!-- Profile Card -->
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm p-4 text-center sticky-top" style="top:80px;">
        <div style="width:120px;height:120px;border-radius:50%;margin:0 auto 1rem;overflow:hidden;border:4px solid var(--accent);">
          <% if (artist.profile_image) { %>
            <img src="<%= artist.profile_image %>" alt="<%= artist.full_name %>" class="w-100 h-100" style="object-fit:cover;" />
          <% } else { %>
            <div class="w-100 h-100 d-flex align-items-center justify-content-center" style="background:var(--accent);font-size:3rem;color:var(--primary);">
              <i class="bi bi-person-fill"></i>
            </div>
          <% } %>
        </div>
        <h4 style="font-family:'Playfair Display',serif;" class="mb-1"><%= artist.full_name %></h4>
        <p class="text-muted mb-2"><i class="bi bi-geo-alt me-1"></i><%= artist.location || artist.district %></p>
        <div class="mb-3">
          <% for (let i = 1; i <= 5; i++) { %>
            <i class="bi bi-star<%= i <= Math.round(artist.average_rating) ? '-fill' : '' %>" style="color:var(--accent);font-size:1rem;"></i>
          <% } %>
          <span class="ms-1 text-muted"><%= Number(artist.average_rating).toFixed(1) %> / 5.0</span>
          <div class="text-muted small"><%= artist.total_reviews %> review(s)</div>
        </div>
        <div class="d-flex justify-content-center gap-3 mb-3">
          <div class="text-center">
            <div class="fw-bold" style="color:var(--primary);">৳<%= artist.hourly_rate %></div>
            <div class="text-muted small">Per Hour</div>
          </div>
          <div class="text-center">
            <div class="fw-bold" style="color:var(--primary);"><%= artist.experience_years %></div>
            <div class="text-muted small">Years Exp.</div>
          </div>
        </div>
        <div class="mb-3">
          <% (artist.specialization || '').split(',').forEach(spec => { %>
            <span class="badge me-1 mb-1" style="background:var(--accent);color:#3a1a00;"><%= spec.trim() %></span>
          <% }) %>
        </div>
        <% if (artist.is_available) { %>
          <div class="badge bg-success py-2 mb-3 w-100"><i class="bi bi-check-circle me-1"></i>Available for Booking</div>
        <% } else { %>
          <div class="badge bg-secondary py-2 mb-3 w-100">Currently Unavailable</div>
        <% } %>
        <div class="d-flex align-items-center justify-content-center gap-2 mb-2">
          <i class="bi bi-shield-check text-success"></i>
          <span class="small text-muted">NID Verified Artist</span>
        </div>
      </div>
    </div>

    <!-- Details -->
    <div class="col-lg-8">
      <!-- Bio -->
      <% if (artist.bio) { %>
      <div class="card border-0 shadow-sm p-4 mb-4">
        <h5 class="fw-semibold mb-3" style="color:var(--primary);">About Me</h5>
        <p class="text-muted"><%= artist.bio %></p>
      </div>
      <% } %>

      <!-- Services -->
      <% if (services.length > 0) { %>
      <div class="card border-0 shadow-sm p-4 mb-4">
        <h5 class="fw-semibold mb-3" style="color:var(--primary);">Services</h5>
        <div class="row g-3">
          <% services.forEach(service => { %>
          <div class="col-sm-6">
            <div class="border rounded p-3 h-100" style="border-color:#f4a261!important;">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <h6 class="fw-semibold mb-0"><%= service.title %></h6>
                <span class="badge" style="background:var(--accent);color:#3a1a00;font-size:0.7rem;"><%= service.category %></span>
              </div>
              <p class="text-muted small mb-2"><%= (service.description || '').substring(0, 100) %></p>
              <div class="d-flex justify-content-between align-items-center mt-auto">
                <span class="fw-bold" style="color:var(--primary);">৳<%= service.price %></span>
                <span class="text-muted small"><i class="bi bi-clock me-1"></i><%= service.duration_minutes %> min</span>
              </div>
              <% if (canBook && artist.is_available) { %>
              <button class="btn btn-sm btn-primary-custom mt-2 w-100" data-bs-toggle="modal" data-bs-target="#bookModal" data-service-id="<%= service.id %>" data-service-title="<%= service.title %>" data-service-price="<%= service.price %>">
                <i class="bi bi-calendar-plus me-1"></i>Book Now
              </button>
              <% } %>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>

      <!-- Products -->
      <% if (products.length > 0) { %>
      <div class="card border-0 shadow-sm p-4 mb-4">
        <h5 class="fw-semibold mb-3" style="color:var(--primary);">Products for Sale</h5>
        <div class="row g-3">
          <% products.forEach(product => { %>
          <div class="col-sm-6 col-md-4">
            <div class="card border-0 h-100 product-card" style="background:#FFF8F0;">
              <% if (product.image_url) { %>
                <img src="<%= product.image_url %>" class="card-img-top" style="height:120px;object-fit:cover;" alt="<%= product.name %>" />
              <% } else { %>
                <div style="height:120px;background:#f5e6d3;" class="d-flex align-items-center justify-content-center">
                  <span style="font-size:2.5rem;">🌿</span>
                </div>
              <% } %>
              <div class="card-body p-2">
                <h6 class="small fw-semibold mb-1"><%= product.name %></h6>
                <div class="d-flex justify-content-between align-items-center">
                  <span class="fw-bold small" style="color:var(--primary);">৳<%= product.price %></span>
                  <a href="/products/<%= product.id %>" class="btn btn-xs btn-sm btn-outline-primary-custom py-0 px-2" style="font-size:0.7rem;">View</a>
                </div>
              </div>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>

      <!-- Portfolio -->
      <% if (portfolios.length > 0) { %>
      <div class="card border-0 shadow-sm p-4 mb-4">
        <h5 class="fw-semibold mb-3" style="color:var(--primary);">Portfolio</h5>
        <div class="row g-2">
          <% portfolios.forEach(item => { %>
          <div class="col-4 col-md-3">
            <div style="height:120px;overflow:hidden;border-radius:8px;" class="shadow-sm">
              <img src="<%= item.image_url %>" class="w-100 h-100" style="object-fit:cover;" alt="<%= item.caption || 'Portfolio' %>" />
            </div>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>

      <!-- Reviews -->
      <div class="card border-0 shadow-sm p-4 mb-4">
        <h5 class="fw-semibold mb-3" style="color:var(--primary);">Customer Reviews (<%= reviews.length %>)</h5>
        <% if (reviews.length === 0) { %>
          <p class="text-muted">No reviews yet. Be the first to book and review!</p>
        <% } else { %>
          <% reviews.forEach(review => { %>
          <div class="border-bottom pb-3 mb-3">
            <div class="d-flex align-items-center gap-2 mb-1">
              <div style="width:36px;height:36px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;color:var(--primary);font-weight:600;font-size:0.85rem;">
                <%= review.customer_name.charAt(0).toUpperCase() %>
              </div>
              <div>
                <div class="fw-semibold small"><%= review.customer_name %></div>
                <div>
                  <% for (let i = 1; i <= 5; i++) { %>
                    <i class="bi bi-star<%= i <= review.rating ? '-fill' : '' %>" style="color:var(--accent);font-size:0.75rem;"></i>
                  <% } %>
                </div>
              </div>
              <div class="ms-auto text-muted small"><%= new Date(review.created_at).toLocaleDateString('en-BD') %></div>
            </div>
            <% if (review.comment) { %><p class="text-muted small mb-0 ms-5"><%= review.comment %></p><% } %>
          </div>
          <% }) %>
        <% } %>

        <% if (canBook) { %>
        <div class="mt-3">
          <h6 class="fw-semibold mb-2">Write a Review</h6>
          <form action="/customer/reviews/artist/<%= artist.user_id %>" method="POST">
            <div class="mb-2">
              <select name="rating" class="form-select form-select-sm" required>
                <option value="">Select Rating</option>
                <option value="5">⭐⭐⭐⭐⭐ Excellent</option>
                <option value="4">⭐⭐⭐⭐ Good</option>
                <option value="3">⭐⭐⭐ Average</option>
                <option value="2">⭐⭐ Poor</option>
                <option value="1">⭐ Very Poor</option>
              </select>
            </div>
            <div class="mb-2">
              <textarea name="comment" class="form-control form-control-sm" rows="2" placeholder="Share your experience..."></textarea>
            </div>
            <button type="submit" class="btn btn-sm btn-primary-custom">Submit Review</button>
          </form>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Booking Modal -->
<% if (canBook) { %>
<div class="modal fade" id="bookModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header" style="background:var(--primary);color:#fff;">
        <h5 class="modal-title"><i class="bi bi-calendar-plus me-2"></i>Book Service</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form action="/customer/book/<%= artist.user_id %>" method="POST">
        <div class="modal-body">
          <input type="hidden" name="service_id" id="modal-service-id" />
          <p class="mb-3">Booking: <strong id="modal-service-title"></strong> — <strong id="modal-service-price" style="color:var(--primary);"></strong></p>
          <div class="mb-3">
            <label class="form-label small fw-semibold">Event Date *</label>
            <input type="date" name="event_date" class="form-control" required min="<%= new Date().toISOString().split('T')[0] %>" />
          </div>
          <div class="mb-3">
            <label class="form-label small fw-semibold">Event Time *</label>
            <input type="time" name="event_time" class="form-control" required />
          </div>
          <div class="mb-3">
            <label class="form-label small fw-semibold">Event Location *</label>
            <input type="text" name="event_location" class="form-control" placeholder="Your address or venue" required />
          </div>
          <div class="mb-3">
            <label class="form-label small fw-semibold">Additional Notes</label>
            <textarea name="notes" class="form-control" rows="2" placeholder="Any special requests..."></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary-custom btn-sm">Confirm Booking</button>
        </div>
      </form>
    </div>
  </div>
</div>
<script>
document.getElementById('bookModal').addEventListener('show.bs.modal', function(e) {
  const btn = e.relatedTarget;
  document.getElementById('modal-service-id').value = btn.dataset.serviceId;
  document.getElementById('modal-service-title').textContent = btn.dataset.serviceTitle;
  document.getElementById('modal-service-price').textContent = '৳' + btn.dataset.servicePrice;
});
</script>
<% } %>
