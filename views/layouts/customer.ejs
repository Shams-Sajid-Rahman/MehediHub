<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'Customer - MehediHub' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
  <%- typeof style !== 'undefined' ? style : '' %>
</head>
<body>
  <!-- Top Navbar -->
  <nav class="navbar navbar-expand-lg" style="background:var(--primary);">
    <div class="container-fluid">
      <a class="navbar-brand text-white fw-bold" href="/">
        <i class="bi bi-flower1 me-2"></i>MehediHub
      </a>
      <div class="ms-auto d-flex align-items-center gap-3">
        <a href="/customer/cart" class="btn btn-sm btn-light position-relative">
          <i class="bi bi-cart3"></i>
          <% if (cartCount > 0) { %>
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:0.65rem;">
              <%= cartCount %>
            </span>
          <% } %>
        </a>
        <span class="text-white small d-none d-md-inline"><i class="bi bi-person-circle me-1"></i><%= currentUser ? currentUser.name : '' %></span>
        <form action="/logout" method="POST" class="m-0">
          <button type="submit" class="btn btn-sm btn-light">Logout</button>
        </form>
      </div>
    </div>
  </nav>

  <div class="d-flex" style="min-height:calc(100vh - 56px);">
    <!-- Sidebar -->
    <nav class="p-3 flex-shrink-0" style="width:220px;background:#fff;border-right:1px solid #eee;min-height:calc(100vh - 56px);">
      <ul class="nav flex-column gap-1">
        <li><a class="nav-link text-dark" href="/customer/dashboard"><i class="bi bi-speedometer2 me-2 text-primary-custom"></i>Dashboard</a></li>
        <li><a class="nav-link text-dark" href="/customer/profile"><i class="bi bi-person me-2 text-primary-custom"></i>My Profile</a></li>
        <li><a class="nav-link text-dark" href="/customer/bookings"><i class="bi bi-calendar-check me-2 text-primary-custom"></i>My Bookings</a></li>
        <li><a class="nav-link text-dark" href="/customer/cart"><i class="bi bi-cart3 me-2 text-primary-custom"></i>Cart <% if (cartCount > 0) { %><span class="badge bg-danger ms-1"><%= cartCount %></span><% } %></a></li>
        <li><a class="nav-link text-dark" href="/customer/orders"><i class="bi bi-box-seam me-2 text-primary-custom"></i>My Orders</a></li>
        <li class="mt-3"><a class="nav-link text-dark" href="/artists"><i class="bi bi-search me-2"></i>Find Artists</a></li>
        <li><a class="nav-link text-dark" href="/products"><i class="bi bi-shop me-2"></i>Shop</a></li>
        <li class="mt-2"><a class="nav-link text-dark" href="/"><i class="bi bi-house me-2"></i>Home</a></li>
      </ul>
    </nav>

    <!-- Main Content -->
    <main class="flex-grow-1 p-4" style="background:#FFF8F0;">
      <%- include('../partials/flash') %>
      <%- body %>
    </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
  <%- typeof script !== 'undefined' ? script : '' %>
</body>
</html>
